options(error = function() {
  traceback(3)
  quit(status = 1, save = "no")
})

expect_false <- function(expr, msg=paste("Expected false for", deparse(subsitutute(expr)))) {
  expr <- force(expr)
  if (expr) {
    stop(msg)
  }
}

expect_true <- function(expr, msg=paste("Expected false for", deparse(subsitutute(expr)))) {
  expr <- force(expr)
  if (!expr) {
    stop(msg)
  }
}

expect_equals <- function(a, b, msg=paste("Expected", deparse(subsitutute(a)), "to be the same as", deparse(subsitutute(b)))) {
  a <- force(a)
  b <- force(b)
  if (!identical(a, b)) {
    stop(msg)
  }
}

# effectivelly preventing the functions from RSH compilation
# FIXME: this is broken, we need a way to flag a function from being compiled
for (x in ls()) {
  f <- get(x)
  if (is.function(f)) {
      assign(x, compiler::cmpfun(f))
  }
}

