    r2 = `*`(k2, 3.141592653589793);
    x1 = ld x;
    check L4() else D1();
  D1():
    deopt 4 [r2, x1];
  L4():
    x2 = force? x1;
    checkMissing(x2);
    r3 = `*`(r2, x2);
    r4 = sin(r3);
    goto L0(r4);
  }
}