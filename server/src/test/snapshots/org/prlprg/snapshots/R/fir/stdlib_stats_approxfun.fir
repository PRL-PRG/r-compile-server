      return R1;
    };
    p5 = prom<V +>{
      na_1 = ld `na.`;
      na_2 = force? na_1;
      checkMissing(na_2);
      return na_2;
    };
    r6 = dyn approx[, , xout, method, rule, `na.rm`](p, p1, p2, p3, p4, p5);
    check L1() else D1();
  D1():
    deopt 12 [r6];
  L1():
    c = `is.object`(r6);
    if c then L3() else L4(r6);
  L2(dx1):
    popenv;
    return dx1;
  L3():
    dr = tryDispatchBuiltin.1("$", r6);
    dc = getTryDispatchBuiltinDispatched(dr);
    if dc then L5() else L4(dr);
  L4(r8):
    r9 = `$`(r8, <sym y>);
    goto L2(r9);
  L5():
    dx = getTryDispatchBuiltinValue(dr);
    goto L2(dx);
  }
}