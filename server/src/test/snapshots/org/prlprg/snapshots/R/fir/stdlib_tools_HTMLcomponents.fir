  L3():
    p = prom<V +>{
      header = ld header;
      header1 = force? header;
      checkMissing(header1);
      return header1;
    };
    ddd1 = ld `...`;
    r3 = dyn c[, `...`](p, ddd1);
    check L4() else D1();
  D1():
    deopt 5 [r3];
  L4():
    goto L0(r3);
  }
}